# Upstox JWT token — get from https://developer.upstox.com
# Refreshed daily; you can also place the token in token.txt at the project root
UPSTOX_TOKEN=your_upstox_jwt_token_here

# HuggingFace API token — get from https://huggingface.co/settings/tokens
# Free tier is sufficient (~1000 requests/day)
HF_API_TOKEN=hf_your_token_here
